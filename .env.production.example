# ══════════════════════════════════════════════════════════════════════════════
# PayForce — Variables de entorno para PRODUCCIÓN
#
# Copia este archivo en Vercel → Settings → Environment Variables.
# NUNCA subas este archivo con valores reales a git.
#
# Leyenda:
#   PUBLIC  → puede exponerse al cliente (prefijo NEXT_PUBLIC_)
#   PRIVATE → solo servidor; nunca expongas al cliente
# ══════════════════════════════════════════════════════════════════════════════

# ── Stripe ────────────────────────────────────────────────────────────────────
# PUBLIC  → clave pública de Stripe (pk_live_... en producción)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REEMPLAZA_ESTO

# PRIVATE → clave secreta de Stripe (sk_live_... en producción)
STRIPE_SECRET_KEY=sk_live_REEMPLAZA_ESTO

# PRIVATE → secreto del webhook de Stripe (whsec_... del Stripe Dashboard)
#           Obtener en: Stripe Dashboard → Developers → Webhooks → tu endpoint
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZA_ESTO

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
# PRIVATE → URL de conexión PostgreSQL
#           Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
#           Supabase: Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROYECTO.supabase.co:5432/postgres?sslmode=require

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# PUBLIC  → URL del proyecto Supabase
#           Supabase: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://PROYECTO.supabase.co

# PUBLIC  → Clave anon pública (safe para exponer al cliente)
#           Supabase: Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...REEMPLAZA_ESTO

# PRIVATE → Clave service_role (acceso total; NUNCA expongas al cliente)
#           Supabase: Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...REEMPLAZA_ESTO

# ── App ───────────────────────────────────────────────────────────────────────
# PUBLIC  → URL pública de la app desplegada (sin barra final)
#           Ejemplo: https://payforce.vercel.app  o  https://tudominio.com
NEXT_PUBLIC_APP_URL=https://tudominio.com
