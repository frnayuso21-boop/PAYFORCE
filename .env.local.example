# ══════════════════════════════════════════════════════════════════════════════
# PayForce — Variables de entorno para DESARROLLO LOCAL
#
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a git (ya está en .gitignore).
#
# Todas las variables marcadas con (*) son OBLIGATORIAS.
# El servidor no arrancará en producción sin ellas.
# ══════════════════════════════════════════════════════════════════════════════

# ── Stripe (*) ────────────────────────────────────────────────────────────────
# Clave pública del dashboard → Developers → API Keys → Publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REEMPLAZA

# Clave secreta (*) — NUNCA al cliente
STRIPE_SECRET_KEY=sk_test_REEMPLAZA

# Secreto del webhook (*) — obtener con: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZA

# ── Base de datos (*) ─────────────────────────────────────────────────────────
# PostgreSQL — Supabase / Railway / Neon / local
# Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/payforce

# ── Supabase Auth (*) ─────────────────────────────────────────────────────────
# Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Supabase → Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_REEMPLAZA

# Supabase → Settings → API → service_role (NUNCA al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ_REEMPLAZA

# ── App (*) ───────────────────────────────────────────────────────────────────
# URL pública de la app — sin barra final
# En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Desarrollo (opcional) ─────────────────────────────────────────────────────
# Saltar autenticación Supabase en local — NUNCA en producción
NEXT_PUBLIC_DEV_BYPASS=false
